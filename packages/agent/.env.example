# Hedera Testnet credentials
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=302e...

# HCS audit topic (create before running live)
HCS_AUDIT_TOPIC_ID=0.0.xxxxx
HCS_REPUTATION_TOPIC_ID=0.0.xxxxx

# OpenAI — enables LangChain agent at POST /api/agent/chat
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Server
PORT=3001
NODE_ENV=development
WEB_UI_URL=http://localhost:3000

# Demo mode: run without Hedera credentials (policies still enforced)
DEMO_MODE=true
