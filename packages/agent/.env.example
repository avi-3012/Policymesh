# =============================================================================
# PolicyMesh Agent — environment template
# Copy: cp packages/agent/.env.example packages/agent/.env
# Full guide: CREDENTIALS.md
# =============================================================================

# --- Hedera testnet (required for live mode) ---
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=302e...
HEDERA_RPC_URL=https://testnet.hashio.io/api

# --- HCS audit (run npm run setup:hcs once) ---
HCS_AUDIT_TOPIC_ID=0.0.xxxxx
HCS_REPUTATION_TOPIC_ID=

# --- OpenAI LangChain agent ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
PORT=3001
NODE_ENV=development
WEB_UI_URL=http://localhost:3000

# --- Mode ---
# DEMO_MODE=true  → no Hedera, simulated external APIs, in-memory audit
# DEMO_MODE=false → live testnet + live integrations (when SERVICES_LIVE_MODE=true)
DEMO_MODE=true
SERVICES_LIVE_MODE=true

# --- Filecoin Calibration (Glif RPC) ---
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FILECOIN_API_KEY=

# --- Akash Console API (use /v1/providers — base URL alone returns 404) ---
AKASH_CONSOLE_API_URL=https://console-api.akash.network
AKASH_API_KEY=
AKASH_NETWORK=mainnet

# --- SaucerSwap + price oracle ---
SAUCERSWAP_RPC_URL=https://testnet.hashio.io/api
SAUCERSWAP_ROUTER_ID=0.0.19264
SAUCERSWAP_QUOTER_ID=0.0.1390002
SAUCERSWAP_WHBAR_TOKEN_ID=0.0.15058
SAUCERSWAP_API_KEY=
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# --- Budget policy (HBAR) ---
MAX_PER_PROCUREMENT=500
MAX_DAILY_SPEND=2000
MAX_MONTHLY_SPEND=20000
MIN_PROCUREMENT_AMOUNT=10

# --- Budget policy (USDC HTS testnet) ---
USDC_TOKEN_ID=0.0.429274
MAX_USDC_PER_PROCUREMENT=100
MIN_USDC_PER_PROCUREMENT=1

# --- Reputation policy ---
MIN_REPUTATION_SCORE=0.75
MAX_FAILURE_RATE=0.05
MIN_COMPLETED_DEALS=50
MAX_PROVIDER_STRIKES=2
REQUIRED_VERIFICATION_LEVEL=verified

# --- Allowlist policy (allowed counterparties) ---
ALLOWLIST_ENABLED=true
ALLOWED_PROVIDER_1=
ALLOWED_PROVIDER_2=
ALLOWED_PROVIDER_3=
ALLOWED_PROVIDERS=

# --- Human confirmation (purchases over threshold need /api/confirmations/:id/approve) ---
CONFIRMATION_THRESHOLD=100
APPROVER_SIGNATURE_THRESHOLD=300

# --- Delivery verification ---
VERIFICATION_TIMEOUT_MINUTES=60
REQUIRED_CONFIRMATIONS=6
AUTO_RETRY=true
MAX_DELIVERY_RETRIES=3
