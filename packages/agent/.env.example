# Hedera Testnet credentials
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=302e...
HEDERA_RPC_URL=https://testnet.hashio.io/api

# HCS audit topic (create before running live)
HCS_AUDIT_TOPIC_ID=0.0.xxxxx
HCS_REPUTATION_TOPIC_ID=

# OpenAI — enables LangChain agent at POST /api/agent/chat
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Server
PORT=3001
NODE_ENV=development
WEB_UI_URL=http://localhost:3000

# Demo mode: run without Hedera credentials (policies still enforced)
# Auto-enabled when HEDERA_ACCOUNT_ID is missing
DEMO_MODE=true

# Live Filecoin / Akash / SaucerSwap APIs (requires DEMO_MODE=false)
# Set SERVICES_LIVE_MODE=false to force simulation even with Hedera credentials
SERVICES_LIVE_MODE=true

# Filecoin Calibration (Glif public RPC — optional premium key)
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FILECOIN_API_KEY=

# Akash Console API (provider list is public; key for JWT deployment APIs)
AKASH_CONSOLE_API_URL=https://console-api.akash.network
AKASH_API_KEY=
AKASH_NETWORK=mainnet

# SaucerSwap + Hedera testnet DEX quotes
SAUCERSWAP_RPC_URL=https://testnet.hashio.io/api
SAUCERSWAP_ROUTER_ID=0.0.19264
SAUCERSWAP_QUOTER_ID=0.0.1390002
SAUCERSWAP_WHBAR_TOKEN_ID=0.0.15058
SAUCERSWAP_API_KEY=

# Price oracle for HBAR→FIL/AKT rates
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# Policy limits (optional overrides)
MAX_PER_PROCUREMENT=500
MAX_DAILY_SPEND=2000
MAX_MONTHLY_SPEND=20000
MIN_REPUTATION_SCORE=0.75
