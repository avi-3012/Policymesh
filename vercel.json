{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install && npm run build --workspace=@policymesh/web",
  "devCommand": "npm run dev --workspace=@policymesh/web",
  "installCommand": "npm install",
  "outputDirectory": "packages/web/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://policymesh.onrender.com/api/:path*"
    }
  ]
}
